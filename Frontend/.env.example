# ════════════════════════════════════════════════════════════════
# Shiv Enterprises — Frontend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file — it is listed in .gitignore.
# ════════════════════════════════════════════════════════════════

# ── API Base URL ────────────────────────────────────────────────
# Development: Vite dev-server proxies /api/* to this address
# (configured in vite.config.js — no need to change unless port changes)
VITE_API_BASE_URL=http://localhost:4000

# ── App Meta ────────────────────────────────────────────────────
VITE_APP_NAME=Shiv Enterprises
VITE_APP_VERSION=1.0.0

# ── Production API (set when deploying) ─────────────────────────
# VITE_API_BASE_URL=https://api.yourdomain.com
