# Server
PORT=4000

# MongoDB – use this same URI in MongoDB Compass to connect to the same database
# Local: mongodb://localhost:27017/shiv_enterprises
# Atlas: mongodb+srv://user:password@cluster.mongodb.net/shiv_enterprises
MONGO_URI=mongodb://localhost:27017/shiv_enterprises

# JWT (change in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
